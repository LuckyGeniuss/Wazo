generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model CustomerGroup {
 id String @id @default(uuid())
 storeId String
 name String
 discountPercentage Float @default(0)
 isDefault Boolean @default(false)
 createdAt DateTime @default(now())
 updatedAt DateTime @updatedAt
 store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
 users User[] @relation("CustomerGroupToUser")
 priceListId String?
 priceList PriceList? @relation(fields: [priceListId], references: [id])
 prices CustomerGroupPrice[]
}

model User {
  id                   String            @id @default(uuid())
  name                 String?
  email                String            @unique
  emailVerified        DateTime?
  image                String?
  password             String?
  role                 Role              @default(USER)
  isBanned             Boolean           @default(false)
  aiGenerationsCount   Int               @default(0)
  loyaltyPoints        Int               @default(0)
  twoFactorEnabled     Boolean           @default(false)
  twoFactorSecret      String?
  twoFactorBackupCodes String[]
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  accounts Account[]
  reviews Review[]
  sessions Session[]
  stores Store[]
  carts Cart[]
  wishlists Wishlist[]
  orders Order[]
  rfqs RFQ[]
  customerGroup CustomerGroup[] @relation("CustomerGroupToUser")
  storeTeamMembers StoreTeamMember[]
  notifications Notification[]
  
  // Phase 31 - SuperAdmin Features
  disputeCases DisputeCase[]
  adminNotifications AdminNotification[]
}

// ==========================================
// NOTIFICATIONS
// ==========================================

model Notification {
  id        String   @id @default(uuid())
  userId    String
  storeId   String?
  type      String // ORDER_NEW | LOW_STOCK | REVIEW_NEW | PAYMENT_RECEIVED | RETURN_NEW
  title     String
  message   String
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, createdAt(sort: Desc)])
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SellerVerification {
  id            String    @id @default(uuid())
  storeId       String    @unique
  status        String    @default("PENDING")
  legalName     String?
  taxId         String?
  documentsUrls String[]  @default([])
  reviewedBy    String?
  reviewedAt    DateTime?
  notes         String?
  createdAt     DateTime  @default(now())
  store         Store     @relation(fields: [storeId], references: [id])
}

model Store {
  id                 String              @id @default(uuid())
  name               String
  domain             String?             @unique
  slug               String              @unique
  ownerId            String
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  isSuspended        Boolean             @default(false)
  themeConfig        Json?               @default("{}")
  banners            Banner[]
  categories         Category[]
  orders             Order[]
  pages              Page[]
  products           Product[]
  carts              Cart[]
  owner              User                @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  integrations       Integration[]
  customerGroups     CustomerGroup[]
  coupons            Coupon[]
  articles           Article[]
  shoppableVideos    ShoppableVideo[]
  subscription       Subscription?
  teamMembers        StoreTeamMember[]
  invites            StoreInvite[]
  deliveryMethods    DeliveryMethod[]
  paymentMethods     PaymentMethod[]
  taxRates           TaxRate[]
  exportFeeds        ExportFeed[]
  apiTokens          ApiToken[]
  priceLists         PriceList[]
  rfqs               RFQ[]
  returnRequests     ReturnRequest[]
  warehouses         Warehouse[]
  rating Float @default(0)
  reviewsCount Int @default(0)
  status String @default("ACTIVE")
  isVerified Boolean @default(false)
  sellerVerification SellerVerification?
    tierPrices TierPrice[]
  
    // Telegram Bot
    telegramChatId String?
    telegramBotEnabled Boolean @default(false)
    telegramLinkCodes TelegramLinkCode[]
  
    // Monetization & Ads
    adCampaigns AdCampaign[]
    
    // Phase 31 - SuperAdmin Features
    healthScore SellerHealthScore?
    disputeCases DisputeCase[]
    adminNotifications AdminNotification[]
    leaderboardEntries SellerLeaderboard[]
  }

model TelegramLinkCode {
  id        String    @id @default(uuid())
  storeId   String
  code      String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  store     Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([code])
  @@index([storeId])
}

model PageView {
  id          String   @id @default(uuid())
  storeId     String
  sessionId   String
  userId      String?
  path        String
  referrer    String?
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  createdAt   DateTime @default(now())

  @@index([storeId, createdAt])
  @@index([sessionId])
}

model Category {
  id String @id @default(uuid())
  name String
  slug String? @unique
  imageUrl String?
  storeId String?
  isGlobal Boolean @default(false)
  parentId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  parent Category? @relation("CategoryToCategory", fields: [parentId], references: [id])
  children Category[] @relation("CategoryToCategory")
  store Store? @relation(fields: [storeId], references: [id], onDelete: Cascade)
  products Product[]
  translations CategoryTranslation[]
}

model Product {
  id String @id @default(uuid())
  externalId String?
  name String
  description String?
  price Float
  compareAtPrice Float? // Для скидок (старая цена)
  stock Int @default(0)
  imageUrl String?
  videoUrl String?
  images String[] @default([])
  colors String[] @default([])
  tags String[] @default([])
  seoTitle String?
  seoDescription String?
  isArchived Boolean @default(false)
  isFeatured Boolean @default(false)
  isDraft Boolean @default(false)
  attributes Json? @default("[]")
  tieredPricing Json? @default("[]")
  upsellProductId String?
  storeId String
  categoryId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  orderItems OrderItem[]
  category Category? @relation(fields: [categoryId], references: [id])
  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
    translations ProductTranslation[]
    upsellProduct Product? @relation("ProductUpsell", fields: [upsellProductId], references: [id])
  upsoldFor Product[] @relation("ProductUpsell")
  reviews Review[]
  wishlists Wishlist[]
  shoppableVideos ShoppableVideo[]
  priceListEntries PriceListEntry[]
  rfqItems RFQItem[]
  warehouseStock WarehouseStock[]
  stockMovements StockMovement[]
  variants ProductVariant[]
  tierPrices TierPrice[]
  prices CustomerGroupPrice[]

  viewsCount Int @default(0)
  salesCount Int @default(0)
  avgRating Float @default(0)
  reviewsCount Int @default(0)
  feedScore Float @default(0)

  @@unique([storeId, externalId])
  @@index([name])
  @@index([isFeatured, isArchived])
  @@index([feedScore(sort: Desc)])
  @@index([categoryId])
  @@index([storeId])
}

model Banner {
  id        String   @id @default(uuid())
  title     String
  imageUrl  String
  link      String?
  location  String   @default("HOME")
  storeId   String?
  isGlobal  Boolean  @default(false)
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  store     Store?   @relation(fields: [storeId], references: [id], onDelete: Cascade)
}

  model Order {
  id String @id @default(uuid())
  storeId String
  status OrderStatus @default(PENDING)
  totalPrice Float
  customerName String
  customerEmail String
  customerPhone String?
  isB2b Boolean @default(false)
  companyName String?
  companyEdrpou String?
  refundReason String?
  reviewRequestSent Boolean @default(false)
  // Відстеження відновлених кошиків
  isRecovered Boolean @default(false)
  recoveryEmailAt DateTime?
  // Stripe Payment Intent ID
  stripePaymentIntentId String?
  // Fraud detection fields
  fraudScore Float?
  fraudFlags String[] @default([])
  fraudStatus String?
  // Internal manager notes
  internalNote String?
  // Nova Poshta delivery fields
  trackingNumber String?
  deliveryCity String?
  deliveryWarehouse String?
  novaPoshtaCityRef String?
  novaPoshtaWarehouseRef String?
  // UTM трекинг
  utmSource String?
  utmMedium String?
  utmCampaign String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  // Ссылка на покупателя (если зарегистрирован)
  userId String?
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]
  returnRequests ReturnRequest[]
  // Історія змін статусу
  statusHistory Json @default("[]")
  
  // Phase 31 - Dispute Cases
  disputeCases DisputeCase[]

  @@index([storeId])
  @@index([storeId, createdAt(sort: Desc)])
}

model OrderItem {
  id String @id @default(uuid())
  orderId String
  productId String
  variantId String?
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  quantity Int @default(1)
  price Float
  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Page {
  id          String   @id @default(uuid())
  name        String
  slug        String
  content     Json     @default("[]")
  isPublished Boolean  @default(false)
  storeId     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  store       Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, slug])
}

model Review {
  id         String   @id @default(uuid())
  rating     Int
  comment    String?
  productId  String
  userId     String?
  isVerified Boolean  @default(false)
  createdAt  DateTime @default(now())
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user       User?    @relation(fields: [userId], references: [id])
}

model Wishlist {
  id        String   @id @default(uuid())
  userId    String
  productId String
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
}

model Coupon {
  id                    String    @id @default(uuid())
  code                  String
  discountValue         Float
  type                  String    @default("PERCENTAGE") // PERCENTAGE или FIXED
  storeId               String
  isActive              Boolean   @default(true)
  isStackable           Boolean   @default(false)
  expiresAt             DateTime?
  minOrderAmount        Float?
  usageLimit            Int?
  usedCount             Int       @default(0)
  applicableProductIds  String[]  @default([])
  applicableCategoryIds String[]  @default([])
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  store                 Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, code])
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  COMPLETED
  CANCELLED
  REFUND_REQUESTED
  REFUNDED
}

enum PriceListType {
  FIXED_PRICE
  PERCENTAGE_DISCOUNT
}

model PriceList {
  id        String        @id @default(uuid())
  storeId   String
  name      String
  type      PriceListType @default(FIXED_PRICE)
  value     Float         @default(0)
  isActive  Boolean       @default(true)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  store          Store            @relation(fields: [storeId], references: [id], onDelete: Cascade)
  entries        PriceListEntry[]
  customerGroups CustomerGroup[]

  @@unique([storeId, name])
}

model PriceListEntry {
  id          String @id @default(uuid())
  priceListId String
  productId   String
  customPrice Float

  priceList PriceList @relation(fields: [priceListId], references: [id], onDelete: Cascade)
  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([priceListId, productId])
}

enum Role {
  USER
  SELLER
  ADMIN
  SUPERADMIN
  MANAGER
  MARKETER
  OWNER
  SUPPORT
}

enum IntegrationProvider {
  OPENAI
  GEMINI
  OPENCART
  UNSPLASH
}

enum FeedFormat {
  YML
  GOOGLE_XML
}

model ExportFeed {
  id        String     @id @default(uuid())
  storeId   String
  name      String
  format    FeedFormat @default(YML)
  urlSlug   String     @unique
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  store     Store      @relation(fields: [storeId], references: [id], onDelete: Cascade)
}

model Integration {
  id           String              @id @default(uuid())
  storeId      String
  providerName IntegrationProvider
  apiKey       String
  extraData    Json?               @default("{}")
  isActive     Boolean             @default(true)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  store        Store               @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, providerName])
}

model Article {
  id          String   @id @default(uuid())
  storeId     String
  title       String
  content     String   @db.Text
  image       String?
  metaTags    String?  @db.Text
  language    String   @default("ru")
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  store       Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
}

model Subscription {
  id                     String    @id @default(uuid())
  storeId                String    @unique
  stripeCustomerId       String?   @unique
  stripeSubscriptionId   String?   @unique
  stripePriceId          String?
  stripeCurrentPeriodEnd DateTime?
  plan                   String    @default("FREE")
  isActive               Boolean   @default(true)
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  store                  Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
}

model ShoppableVideo {
  id        String   @id @default(uuid())
  storeId   String
  productId String
  videoUrl  String
  title     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model StoreTeamMember {
  id        String   @id @default(uuid())
  storeId   String
  userId    String
  role      Role     @default(MANAGER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([storeId, userId])
}

model Cart {
  id        String   @id @default(uuid())
  userId    String
  storeId   String
  items     Json     @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  store     Store                   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  campaigns AbandonedCartCampaign[]

  @@unique([userId, storeId])
}

enum AbandonedCartStatus {
  PENDING
  SENT
  RECOVERED
}

model AbandonedCartCampaign {
  id           String              @id @default(uuid())
  cartId       String
  status       AbandonedCartStatus @default(PENDING)
  scheduledFor DateTime?
  sentAt       DateTime?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  cart Cart @relation(fields: [cartId], references: [id], onDelete: Cascade)
}

model StoreInvite {
  id        String   @id @default(uuid())
  storeId   String
  email     String
  role      Role     @default(MANAGER)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, email])
}

model DeliveryMethod {
  id               String   @id @default(uuid())
  storeId          String
  name             String
  cost             Float    @default(0)
  freeShippingFrom Float?
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  store            Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
}

model PaymentMethod {
  id        String   @id @default(uuid())
  storeId   String
  name      String
  type      String   @default("CASH") // CASH, CARD, TRANSFER
  details   Json?    @default("{}")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
}

model TaxRate {
  id        String   @id @default(uuid())
  storeId   String
  name      String
  rate      Float    @default(0) // В процентах (например, 20 для 20%)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
}

model PlatformSettings {
  id                String   @id @default("platform")
  isMaintenanceMode Boolean  @default(false)
  maxStoresPerUser  Int      @default(3)
  supportEmail      String   @default("support@platform.com")
  updatedAt         DateTime @updatedAt
}

model ApiToken {
  id         String    @id @default(uuid())
  storeId    String
  name       String
  tokenHash  String    @unique
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())
  store      Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId])
}

enum RFQStatus {
  PENDING
  QUOTED
  ACCEPTED
  REJECTED
}

model RFQ {
  id          String    @id @default(uuid())
  storeId     String
  userId      String?
  status      RFQStatus @default(PENDING)
  note        String?   @db.Text
  totalAmount Float?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  store Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  user  User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  items RFQItem[]

  @@index([storeId])
  @@index([userId])
}

model RFQItem {
  id          String @id @default(uuid())
  rfqId       String
  productId   String
  quantity    Int
  targetPrice Float?

  rfq     RFQ     @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([rfqId])
  @@index([productId])
}

model Currency {
  code      String   @id
  name      String
  symbol    String
  rate      Float    @default(1)
  isDefault Boolean  @default(false)
  updatedAt DateTime @updatedAt
}

// ==========================================
// AUDIT LOG
// ==========================================

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  INVITE_SENT
  INVITE_ACCEPTED
  ORDER_STATUS_CHANGED
  ROLE_CHANGED
  SETTINGS_CHANGED
}

model AuditLog {
  id        String      @id @default(uuid())
  storeId   String?
  userId    String?
  action    AuditAction
  entity    String // "Product", "Order", "User", etc.
  entityId  String?
  oldData   Json?       @default("{}")
  newData   Json?       @default("{}")
  ipAddress String?
  userAgent String?
  createdAt DateTime    @default(now())

  @@index([storeId, createdAt(sort: Desc)])
  @@index([userId])
  @@index([entity, entityId])
}

// ==========================================
// RETURNS & REFUNDS
// ==========================================

enum ReturnStatus {
  PENDING
  APPROVED
  REJECTED
  REFUNDED
}

enum RefundMethod {
  ORIGINAL_PAYMENT
  STORE_CREDIT
  BANK_TRANSFER
}

model ReturnRequest {
  id             String       @id @default(uuid())
  orderId        String
  storeId        String
  status         ReturnStatus @default(PENDING)
  reason         String       @db.Text
  customerNote   String?      @db.Text
  staffNote      String?      @db.Text
  refundAmount   Float?
  refundMethod   RefundMethod @default(ORIGINAL_PAYMENT)
  stripeRefundId String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  order          Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  store          Store        @relation(fields: [storeId], references: [id], onDelete: Cascade)
  items          ReturnItem[]

  @@index([storeId, createdAt(sort: Desc)])
  @@index([orderId])
  @@index([status])
}

model ReturnItem {
  id              String        @id @default(uuid())
  returnRequestId String
  orderItemId     String
  quantity        Int
  reason          String?
  returnRequest   ReturnRequest @relation(fields: [returnRequestId], references: [id], onDelete: Cascade)

  @@index([returnRequestId])
}

// ==========================================
// INVENTORY MANAGEMENT 2.0
// ==========================================

model Warehouse {
  id        String           @id @default(uuid())
  storeId   String
  name      String
  address   String?
  isDefault Boolean          @default(false)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  store     Store            @relation(fields: [storeId], references: [id], onDelete: Cascade)
  stock     WarehouseStock[]
  movements StockMovement[]

  @@index([storeId])
}

model WarehouseStock {
  id          String    @id @default(uuid())
  warehouseId String
  productId   String
  variantSku  String?
  quantity    Int       @default(0)
  reserved    Int       @default(0)
  available   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([warehouseId, productId, variantSku])
  @@index([productId])
  @@index([warehouseId])
}

enum StockMovementType {
  RECEIPT
  SALE
  RETURN
  ADJUSTMENT
  TRANSFER
}

model StockMovement {
  id          String            @id @default(uuid())
  productId   String
  warehouseId String
  type        StockMovementType
  quantity    Int
  reason      String?
  orderId     String?
  createdAt   DateTime          @default(now())
  warehouse   Warehouse         @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  product     Product           @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, createdAt(sort: Desc)])
  @@index([warehouseId])
}

// ==========================================
// BACKGROUND JOBS (Poor Man's Queue)
// ==========================================

enum BackgroundJobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum BackgroundJobType {
  SEND_EMAIL
  SEND_ORDER_CONFIRMATION
  RECALCULATE_FEED_SCORE
  EXPORT_PRODUCTS
  GENERATE_SITEMAP
}

model BackgroundJob {
  id         String              @id @default(uuid())
  type       BackgroundJobType
  status     BackgroundJobStatus @default(PENDING)
  payload    Json                @default("{}")
  runAt      DateTime            @default(now())
  startedAt  DateTime?
  finishedAt DateTime?
  error      String?             @db.Text
  attempts   Int                 @default(0)
  maxRetries Int                 @default(3)
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  @@index([status, runAt])
  @@index([type, status])
}

// ==========================================
// EMAIL CAMPAIGNS (Marketing)
// ==========================================


// ==========================================
// PRODUCT VARIANTS (Module 83)
// ==========================================

model ProductVariant {
  id String @id @default(uuid())
  productId String
  name String // напр., "Білий / M" або "Red / Large"
  sku String? // Унікальний артикул варіанту
  price Float? // Якщо null, використовується ціна з Product
  stock Int @default(0) // Залишок цього конкретного варіанту
  options Json // Збереження виборів: {"Колір": "Білий", "Розмір": "M"}

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@index([productId])
}
  
  // ==========================================
  // MULTILINGUAL TRANSLATIONS (Module 84)
  // ==========================================
  model ProductTranslation {
    id String @id @default(uuid())
    productId String
    locale String
    name String
    description String? @db.Text
    seoTitle String?
    seoDescription String?
  
    product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  
    @@unique([productId, locale])
    @@index([productId])
  
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
  }
  
  model CategoryTranslation {
    id String @id @default(uuid())
    categoryId String
    locale String
    name String
    description String? @db.Text
  
    category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  
    @@unique([categoryId, locale])
    @@index([categoryId])
  
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
  }
  
  // ==========================================
  // TIERED PRICING (Module 58)
  // ==========================================
  
  model TierPrice {
    id String @id @default(uuid())
    productId String
    minQuantity Int
    price Float
    storeId String
    product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
    store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
  
    @@unique([productId, minQuantity])
    @@index([productId])
    @@index([storeId])
  }
  
  // ==========================================
  // CUSTOMER GROUP PRICING (Module 59)
  // ==========================================
  
  model CustomerGroupPrice {
    id String @id @default(uuid())
    customerGroupId String
    productId String
    price Float
    customerGroup CustomerGroup @relation(fields: [customerGroupId], references: [id], onDelete: Cascade)
    product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  
    @@unique([customerGroupId, productId])
    @@index([customerGroupId])
    @@index([productId])
  }
  
  // ==========================================
  // ERROR LOGGING (Module 80)
  // ==========================================
  
  model ErrorLog {
    id String @id @default(uuid())
    type String // "FRONTEND" | "BACKEND" | "DATABASE" | "API"
    message String @db.Text
    stackTrace String? @db.Text
    userId String?
    storeId String?
    url String?
    userAgent String?
    severity String @default("ERROR") // "ERROR" | "WARNING" | "INFO"
    metadata Json? @default("{}")
    createdAt DateTime @default(now())
  
    @@index([type])
    @@index([severity])
    @@index([userId])
    @@index([storeId])
    @@index([createdAt(sort: Desc)])
  }
  
  // ==========================================
  // PLATFORM MONETIZATION & AD SYSTEM
  // ==========================================
  
  enum AdCampaignType {
    CPC // Cost Per Click
    CPA // Cost Per Action
    CPM // Cost Per Mille (impressions)
  }
  
  enum AdCampaignStatus {
    DRAFT
    ACTIVE
    PAUSED
    COMPLETED
    REJECTED
  }
  
  enum AdPlacement {
    MARKETPLACE_HEADER
    MARKETPLACE_SIDEBAR
    STOREFRONT_HEADER
    STOREFRONT_SIDEBAR
    PRODUCT_DETAIL
    CATEGORY_PAGE
    CHECKOUT_PAGE
    SEARCH_RESULTS
  }
  
  model AdCampaign {
    id String @id @default(uuid())
    storeId String
    name String
    type AdCampaignType @default(CPC)
    status AdCampaignStatus @default(DRAFT)
    
    // Budget & Bidding
    dailyBudget Float?
    totalBudget Float?
    maxBid Float // Maximum bid per click/action
    currentBid Float // Current active bid
    
    // Targeting
    targetCategories String[] @default([]) // Category IDs
    targetKeywords String[] @default([])
    targetStores String[] @default([]) // Show on specific stores
    
    // Placement
    placements AdPlacement[] @default([])
    
    // Creative
    title String
    description String?
    imageUrl String?
    linkUrl String // Destination URL
    
    // Tracking
    startDate DateTime?
    endDate DateTime?
    
    // Stats (denormalized for performance)
      impressionsCount Int @default(0)
      clicksCount Int @default(0)
      conversionsCount Int @default(0)
      spentAmount Float @default(0)
    
      createdAt DateTime @default(now())
      updatedAt DateTime @updatedAt
    
      store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
      items AdCampaignItem[]
      adImpressions AdImpression[]
    
    @@index([storeId])
    @@index([status])
    @@index([createdAt])
  }
  
  model AdCampaignItem {
    id String @id @default(uuid())
    campaignId String
    productId String?
    categoryId String?
    
    campaign AdCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
    
    @@index([campaignId])
  }
  
  model AdImpression {
    id String @id @default(uuid())
    campaignId String
    storeId String? // Where impression occurred
    userId String?
    
    placement AdPlacement
    occurredAt DateTime @default(now())
    clicked Boolean @default(false)
    converted Boolean @default(false)
    
    campaign AdCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
    
    @@index([campaignId])
    @@index([storeId])
    @@index([occurredAt])
  }
  
  model PlatformMonetization {
    id String @id @default(uuid())
    
    // Platform-wide settings
    adEnabled Boolean @default(true)
    minCpcBid Float @default(0.01)
    maxCpcBid Float @default(100.0)
    minCpaBid Float @default(0.1)
    maxCpaBid Float @default(1000.0)
    platformCommission Float @default(0.05) // 5% default
    
    // Revenue tracking
    totalRevenue Float @default(0)
    adRevenue Float @default(0)
    subscriptionRevenue Float @default(0)
    commissionRevenue Float @default(0)
    
    updatedAt DateTime @updatedAt
    
    @@unique([id])
  }
  
  // ==========================================
  // MARKETPLACE THEMES
  // ==========================================
  
  model MarketplaceTheme {
    id String @id @default(uuid())
    name String
    slug String @unique
    description String?
    
    // Theme configuration
    config Json @default("{}")
    
    // Styling
    primaryColor String @default("#3b82f6")
    secondaryColor String @default("#64748b")
    accentColor String @default("#22c55e")
    backgroundColor String @default("#ffffff")
    textColor String @default("#1e293b")
    
    // Layout
    headerStyle String @default("default") // default, minimal, centered
    footerStyle String @default("default")
    productCardStyle String @default("default")
    
    // Features
    showRatings Boolean @default(true)
    showCompare Boolean @default(true)
    showWishlist Boolean @default(true)
    quickViewEnabled Boolean @default(true)
    
    isActive Boolean @default(false)
    isPremium Boolean @default(false)
    price Float @default(0)
    
    previewImageUrl String?
    
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
    
    @@index([isActive])
    @@index([slug])
  }
  
  // ==========================================
  // PHASE 31: ADVANCED SUPERADMIN FEATURES
  // ==========================================
  
  // Seller Health Score - комплексна оцінка продавця
  model SellerHealthScore {
    id String @id @default(uuid())
    storeId String @unique
    
    // Основні метрики (0-100)
    overallScore Float @default(50)
    orderFulfillmentScore Float @default(50)
    customerServiceScore Float @default(50)
    productQualityScore Float @default(50)
    shippingSpeedScore Float @default(50)
    communicationScore Float @default(50)
    
    // Деталі
    totalOrders Int @default(0)
    completedOrders Int @default(0)
    cancelledOrders Int @default(0)
    avgShippingTimeHours Float @default(0)
    avgResponseTimeHours Float @default(0)
    returnRate Float @default(0)
    disputeRate Float @default(0)
    avgRating Float @default(0)
    
    // Рівень продавця
    tier String @default("BRONZE") // BRONZE, SILVER, GOLD, PLATINUM, DIAMOND
    
    lastCalculatedAt DateTime @default(now())
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
    
    store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
    
    @@index([storeId])
    @@index([overallScore])
    @@index([tier])
  }
  
  // Dispute Resolution System
  enum DisputeStatus {
    OPEN
    IN_REVIEW
    CUSTOMER_RESPONDED
    SELLER_RESPONDED
    UNDER_SUPERADMIN_REVIEW
    RESOLVED_CUSTOMER
    RESOLVED_SELLER
    ESCALATED
    CLOSED
  }
  
  enum DisputeType {
    PRODUCT_NOT_RECEIVED
    PRODUCT_DAMAGED
    PRODUCT_NOT_AS_DESCRIBED
    WRONG_ITEM
    REFUND_ISSUE
    SHIPPING_ISSUE
    OTHER
  }
  
  model DisputeCase {
    id String @id @default(uuid())
    
    // Зв'язки
    orderId String
    storeId String
    userId String
    assignedAdminId String?
    
    // Інформація
    type DisputeType
    status DisputeStatus @default(OPEN)
    title String
    description String @db.Text
    customerNote String? @db.Text
    sellerNote String? @db.Text
    adminNote String? @db.Text
    
    // Вимога покупця
    requestedResolution String @default("REFUND") // REFUND, REPLACEMENT, PARTIAL_REFUND
    refundAmount Float?
    
    // Рішення
    finalDecision String? // CUSTOMER, SELLER, COMPROMISE
    decisionReason String? @db.Text
    resolvedAt DateTime?
    
    // Пріоритет (автоматично)
    priority String @default("NORMAL") // LOW, NORMAL, HIGH, CRITICAL
    daysOpen Int @default(0)
    
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
    
    order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
    store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
    user User @relation(fields: [userId], references: [id], onDelete: Cascade)
    messages DisputeMessage[]
    
    @@index([storeId])
    @@index([userId])
    @@index([status])
    @@index([createdAt])
    @@index([priority])
  }
  
  model DisputeMessage {
    id String @id @default(uuid())
    
    disputeCaseId String
    senderId String? // null для системних повідомлень
    senderType String // CUSTOMER, SELLER, SYSTEM, ADMIN
    message String @db.Text
    attachments String[] @default([])
    isVisibleToBoth Boolean @default(true)
    
    createdAt DateTime @default(now())
    
    disputeCase DisputeCase @relation(fields: [disputeCaseId], references: [id], onDelete: Cascade)
    
    @@index([disputeCaseId])
    @@index([senderType])
  }
  
  // Smart Admin Notifications
  enum AdminNotificationType {
    CRITICAL_ALERT
    HIGH_PRIORITY_DISPUTE
    SELLER_MILESTONE
    PLATFORM_ANOMALY
    REVENUE_MILESTONE
    SYSTEM_ALERT
    HEALTH_SCORE_DROP
    VERIFICATION_PENDING
    FRAUD_ALERT
  }
  
  enum AdminNotificationSeverity {
    LOW
    MEDIUM
    HIGH
    CRITICAL
  }
  
  model AdminNotification {
    id String @id @default(uuid())
    
    type AdminNotificationType
    severity AdminNotificationSeverity @default(MEDIUM)
    
    title String
    message String @db.Text
    
    // Зв'язки (опціонально)
    storeId String?
    userId String?
    orderId String?
    disputeId String?
    
    // Дії
    actionLabel String?
    actionUrl String?
    
    // Статус
    isRead Boolean @default(false)
    isArchived Boolean @default(false)
    
    // Мета для UI
    metadata Json @default("{}")
    
    createdAt DateTime @default(now())
    expiresAt DateTime?
    
    store Store? @relation(fields: [storeId], references: [id], onDelete: SetNull)
    user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
    
    @@index([isRead])
    @@index([severity])
    @@index([type])
    @@index([createdAt])
    @@index([storeId])
  }
  
  // Leaderboard Cache - для продуктивності
  model SellerLeaderboard {
    id String @id @default(uuid())
    
    storeId String @unique
    storeName String
    
    // Поточний рейтинг
    overallRank Int
    categoryRanks Json @default("{}") // {"electronics": 1, "fashion": 5}
    
    // Метрики для розрахунку
    healthScore Float
    totalSales Float
    totalOrders Int
    avgRating Float
    responseRate Float
    onTimeShipmentRate Float
    
    // Період
    period String @default("MONTHLY") // WEEKLY, MONTHLY, QUARTERLY, YEARLY, ALL_TIME
    periodStart DateTime
    periodEnd DateTime?
    
    // Бейджі
    badges String[] @default([]) // "TOP_SELLER", "FAST_SHIPPER", "EXCELLENT_SERVICE", etc.
    
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
    
    store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
    
    @@index([overallRank])
    @@index([period])
    @@index([healthScore])
  }
  

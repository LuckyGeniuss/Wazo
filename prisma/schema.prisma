generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model CustomerGroup {
  id                 String               @id @default(uuid())
  storeId            String
  name               String
  discountPercentage Float                @default(0)
  isDefault          Boolean              @default(false)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  priceListId        String?
  priceList          PriceList?           @relation(fields: [priceListId], references: [id])
  store              Store                @relation(fields: [storeId], references: [id], onDelete: Cascade)
  prices             CustomerGroupPrice[]
  users              User[]               @relation("CustomerGroupToUser")
}

model User {
  id                   String              @id @default(uuid())
  name                 String?
  email                String              @unique
  emailVerified        DateTime?
  image                String?
  password             String?
  role                 Role                @default(USER)
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  aiGenerationsCount   Int                 @default(0)
  isBanned             Boolean             @default(false)
  loyaltyPoints        Int                 @default(0)
  twoFactorBackupCodes String[]
  twoFactorEnabled     Boolean             @default(false)
  twoFactorSecret      String?
  accounts             Account[]
  adminNotifications   AdminNotification[]
  carts                Cart[]
  disputeCases         DisputeCase[]
  notifications        Notification[]
  orders               Order[]
  rfqs                 RFQ[]
  reviews              Review[]
  sessions             Session[]
  stores               Store[]
  storeTeamMembers     StoreTeamMember[]
  wishlists            Wishlist[]
  customerGroup        CustomerGroup[]     @relation("CustomerGroupToUser")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  storeId   String?
  type      String
  title     String
  message   String
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, createdAt(sort: Desc)])
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SellerVerification {
  id            String    @id @default(uuid())
  storeId       String    @unique
  status        String    @default("PENDING")
  legalName     String?
  taxId         String?
  documentsUrls String[]  @default([])
  reviewedBy    String?
  reviewedAt    DateTime?
  notes         String?
  createdAt     DateTime  @default(now())
  store         Store     @relation(fields: [storeId], references: [id])
}

model Store {
  id                 String              @id @default(uuid())
  name               String
  domain             String?             @unique
  slug               String              @unique
  ownerId            String
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  isSuspended        Boolean             @default(false)
  isVerified         Boolean             @default(false)
  novaPoshtaApiKey   String?
  openaiApiKey       String?
  rating             Float               @default(0)
  reviewsCount       Int                 @default(0)
  status             String              @default("ACTIVE")
  stripeAccountId    String?
  telegramBotEnabled Boolean             @default(false)
  telegramChatId     String?
  themeConfig        Json?               @default("{}")
  adCampaigns        AdCampaign[]
  adminNotifications AdminNotification[]
  apiTokens          ApiToken[]
  articles           Article[]
  banners            Banner[]
  carts              Cart[]
  categories         Category[]
  coupons            Coupon[]
  customerGroups     CustomerGroup[]
  deliveryMethods    DeliveryMethod[]
  disputeCases       DisputeCase[]
  exportFeeds        ExportFeed[]
  integrations       Integration[]
  orders             Order[]
  pages              Page[]
  paymentMethods     PaymentMethod[]
  priceLists         PriceList[]
  products           Product[]
  rfqs               RFQ[]
  returnRequests     ReturnRequest[]
  healthScore        SellerHealthScore?
  leaderboardEntries SellerLeaderboard?
  sellerVerification SellerVerification?
  shoppableVideos    ShoppableVideo[]
  owner              User                @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  invites            StoreInvite[]
  storeSettings      StoreSettings?
  teamMembers        StoreTeamMember[]
  subscription       Subscription?
  taxRates           TaxRate[]
  telegramLinkCodes  TelegramLinkCode[]
  tierPrices         TierPrice[]
  warehouses         Warehouse[]
}

model StoreSettings {
  id                   String   @id @default(uuid())
  storeId              String   @unique
  primaryColor         String   @default("#3b82f6")
  secondaryColor       String   @default("#64748b")
  accentColor          String   @default("#22c55e")
  backgroundColor      String   @default("#ffffff")
  textColor            String   @default("#1e293b")
  heroBannerUrl        String?
  heroTitle            String?
  heroSubtitle         String?
  showCategories       Boolean  @default(true)
  showFeaturedProducts Boolean  @default(true)
  productsLayout       String   @default("grid")
  productsPerRow       Int      @default(4)
  headerLogo           String?
  footerText           String?
  footerLinks          Json     @default("[]")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  store                Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId])
}

model TelegramLinkCode {
  id        String    @id @default(uuid())
  storeId   String
  code      String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  store     Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([code])
  @@index([storeId])
}

model PageView {
  id          String   @id @default(uuid())
  storeId     String
  sessionId   String
  userId      String?
  path        String
  referrer    String?
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  createdAt   DateTime @default(now())

  @@index([storeId, createdAt])
  @@index([sessionId])
}

model Category {
  id           String                @id @default(uuid())
  name         String
  storeId      String?
  isGlobal     Boolean               @default(false)
  parentId     String?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  imageUrl     String?
  slug         String?               @unique
  parent       Category?             @relation("CategoryToCategory", fields: [parentId], references: [id])
  children     Category[]            @relation("CategoryToCategory")
  store        Store?                @relation(fields: [storeId], references: [id], onDelete: Cascade)
  translations CategoryTranslation[]
  products     Product[]
}

model Product {
  id               String               @id @default(uuid())
  name             String
  description      String?
  price            Float
  imageUrl         String?
  isArchived       Boolean              @default(false)
  isFeatured       Boolean              @default(false)
  storeId          String
  categoryId       String?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  attributes       Json?                @default("[]")
  avgRating        Float                @default(0)
  colors           String[]             @default([])
  compareAtPrice   Float?
  externalId       String?
  feedScore        Float                @default(0)
  images           String[]             @default([])
  isDraft          Boolean              @default(false)
  reviewsCount     Int                  @default(0)
  salesCount       Int                  @default(0)
  seoDescription   String?
  seoTitle         String?
  stock            Int                  @default(0)
  tags             String[]             @default([])
  tieredPricing    Json?                @default("[]")
  upsellProductId  String?
  videoUrl         String?
  viewsCount       Int                  @default(0)
  prices           CustomerGroupPrice[]
  orderItems       OrderItem[]
  priceListEntries PriceListEntry[]
  category         Category?            @relation(fields: [categoryId], references: [id])
  store            Store                @relation(fields: [storeId], references: [id], onDelete: Cascade)
  upsellProduct    Product?             @relation("ProductUpsell", fields: [upsellProductId], references: [id])
  upsoldFor        Product[]            @relation("ProductUpsell")
  translations     ProductTranslation[]
  variants         ProductVariant[]
  rfqItems         RFQItem[]
  reviews          Review[]
  shoppableVideos  ShoppableVideo[]
  stockMovements   StockMovement[]
  tierPrices       TierPrice[]
  warehouseStock   WarehouseStock[]
  wishlists        Wishlist[]

  @@unique([storeId, externalId])
  @@index([name])
  @@index([isFeatured, isArchived])
  @@index([feedScore(sort: Desc)])
  @@index([categoryId])
  @@index([storeId])
}

model Banner {
  id        String   @id @default(uuid())
  title     String
  imageUrl  String
  link      String?
  location  String   @default("HOME")
  storeId   String?
  isGlobal  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  store     Store?   @relation(fields: [storeId], references: [id], onDelete: Cascade)
}

model Order {
id String @id @default(uuid())
storeId String
totalPrice Float
customerName String
customerEmail String
customerPhone String?
createdAt DateTime @default(now())
updatedAt DateTime @updatedAt
paymentMethod String?
shippingAddress String?
comment String?
recipientType String? @default("self")
recipientName String?
recipientPhone String?
  companyEdrpou          String?
  companyName            String?
  deliveryCity           String?
  deliveryWarehouse      String?
  fraudFlags             String[]        @default([])
  fraudScore             Float?
  fraudStatus            String?
  internalNote           String?
  isB2b                  Boolean         @default(false)
  isRecovered            Boolean         @default(false)
  novaPoshtaCityRef      String?
  novaPoshtaWarehouseRef String?
  recoveryEmailAt        DateTime?
  refundReason           String?
  reviewRequestSent      Boolean         @default(false)
  statusHistory          Json            @default("[]")
  stripePaymentIntentId  String?
  trackingNumber         String?
  userId                 String?
  utmCampaign            String?
  utmMedium              String?
  utmSource              String?
  status                 OrderStatus     @default(PENDING)
  disputeCases           DisputeCase[]
  store                  Store           @relation(fields: [storeId], references: [id], onDelete: Cascade)
  user                   User?           @relation(fields: [userId], references: [id])
  orderItems             OrderItem[]
  returnRequests         ReturnRequest[]

  @@index([storeId])
  @@index([storeId, createdAt(sort: Desc)])
}

model OrderItem {
  id        String          @id @default(uuid())
  orderId   String
  productId String
  quantity  Int             @default(1)
  price     Float
  variantId String?
  order     Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant   ProductVariant? @relation(fields: [variantId], references: [id])
}

model Page {
  id          String   @id @default(uuid())
  name        String
  slug        String
  content     Json     @default("[]")
  isPublished Boolean  @default(false)
  storeId     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  store       Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, slug])
}

model Review {
  id         String   @id @default(uuid())
  rating     Int
  comment    String?
  productId  String
  userId     String?
  isVerified Boolean  @default(false)
  createdAt  DateTime @default(now())
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user       User?    @relation(fields: [userId], references: [id])
}

model Wishlist {
  id        String   @id @default(uuid())
  userId    String
  productId String
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
}

model Coupon {
  id                    String    @id @default(uuid())
  code                  String
  discountValue         Float
  type                  String    @default("PERCENTAGE")
  storeId               String
  isActive              Boolean   @default(true)
  isStackable           Boolean   @default(false)
  expiresAt             DateTime?
  minOrderAmount        Float?
  usageLimit            Int?
  usedCount             Int       @default(0)
  applicableProductIds  String[]  @default([])
  applicableCategoryIds String[]  @default([])
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  store                 Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, code])
}

model PriceList {
  id             String           @id @default(uuid())
  storeId        String
  name           String
  type           PriceListType    @default(FIXED_PRICE)
  value          Float            @default(0)
  isActive       Boolean          @default(true)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  customerGroups CustomerGroup[]
  store          Store            @relation(fields: [storeId], references: [id], onDelete: Cascade)
  entries        PriceListEntry[]

  @@unique([storeId, name])
}

model PriceListEntry {
  id          String    @id @default(uuid())
  priceListId String
  productId   String
  customPrice Float
  priceList   PriceList @relation(fields: [priceListId], references: [id], onDelete: Cascade)
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([priceListId, productId])
}

model ExportFeed {
  id        String     @id @default(uuid())
  storeId   String
  name      String
  format    FeedFormat @default(YML)
  urlSlug   String     @unique
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  store     Store      @relation(fields: [storeId], references: [id], onDelete: Cascade)
}

model Integration {
  id           String              @id @default(uuid())
  storeId      String
  providerName IntegrationProvider
  apiKey       String
  extraData    Json?               @default("{}")
  isActive     Boolean             @default(true)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  store        Store               @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, providerName])
}

model Article {
  id          String   @id @default(uuid())
  storeId     String
  title       String
  content     String
  image       String?
  metaTags    String?
  language    String   @default("ru")
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  store       Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
}

model Subscription {
  id                     String    @id @default(uuid())
  storeId                String    @unique
  stripeCustomerId       String?   @unique
  stripeSubscriptionId   String?   @unique
  stripePriceId          String?
  stripeCurrentPeriodEnd DateTime?
  plan                   String    @default("FREE")
  isActive               Boolean   @default(true)
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  store                  Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
}

model ShoppableVideo {
  id        String   @id @default(uuid())
  storeId   String
  productId String
  videoUrl  String
  title     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
}

model StoreTeamMember {
  id        String   @id @default(uuid())
  storeId   String
  userId    String
  role      Role     @default(MANAGER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([storeId, userId])
}

model Cart {
  id        String                  @id @default(uuid())
  userId    String
  storeId   String
  items     Json                    @default("[]")
  createdAt DateTime                @default(now())
  updatedAt DateTime                @updatedAt
  campaigns AbandonedCartCampaign[]
  store     Store                   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  user      User                    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, storeId])
}

model AbandonedCartCampaign {
  id           String              @id @default(uuid())
  cartId       String
  status       AbandonedCartStatus @default(PENDING)
  scheduledFor DateTime?
  sentAt       DateTime?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  cart         Cart                @relation(fields: [cartId], references: [id], onDelete: Cascade)
}

model StoreInvite {
  id        String   @id @default(uuid())
  storeId   String
  email     String
  role      Role     @default(MANAGER)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, email])
}

model DeliveryMethod {
  id               String   @id @default(uuid())
  storeId          String
  name             String
  cost             Float    @default(0)
  freeShippingFrom Float?
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  store            Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
}

model PaymentMethod {
  id        String   @id @default(uuid())
  storeId   String
  name      String
  type      String   @default("CASH")
  details   Json?    @default("{}")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
}

model TaxRate {
  id        String   @id @default(uuid())
  storeId   String
  name      String
  rate      Float    @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
}

model PlatformSettings {
  id                String   @id @default("platform")
  isMaintenanceMode Boolean  @default(false)
  maxStoresPerUser  Int      @default(3)
  supportEmail      String   @default("support@platform.com")
  updatedAt         DateTime @updatedAt
}

model ApiToken {
  id         String    @id @default(uuid())
  storeId    String
  name       String
  tokenHash  String    @unique
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())
  store      Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId])
}

model RFQ {
  id          String    @id @default(uuid())
  storeId     String
  userId      String?
  status      RFQStatus @default(PENDING)
  note        String?
  totalAmount Float?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  store       Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  user        User?     @relation(fields: [userId], references: [id])
  items       RFQItem[]

  @@index([storeId])
  @@index([userId])
}

model RFQItem {
  id          String  @id @default(uuid())
  rfqId       String
  productId   String
  quantity    Int
  targetPrice Float?
  product     Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  rfq         RFQ     @relation(fields: [rfqId], references: [id], onDelete: Cascade)

  @@index([rfqId])
  @@index([productId])
}

model Currency {
  code      String   @id
  name      String
  symbol    String
  rate      Float    @default(1)
  isDefault Boolean  @default(false)
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id        String      @id @default(uuid())
  storeId   String?
  userId    String?
  action    AuditAction
  entity    String
  entityId  String?
  oldData   Json?       @default("{}")
  newData   Json?       @default("{}")
  ipAddress String?
  userAgent String?
  createdAt DateTime    @default(now())

  @@index([storeId, createdAt(sort: Desc)])
  @@index([userId])
  @@index([entity, entityId])
}

model ReturnRequest {
  id             String       @id @default(uuid())
  orderId        String
  storeId        String
  status         ReturnStatus @default(PENDING)
  reason         String
  customerNote   String?
  staffNote      String?
  refundAmount   Float?
  refundMethod   RefundMethod @default(ORIGINAL_PAYMENT)
  stripeRefundId String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  items          ReturnItem[]
  order          Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  store          Store        @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId, createdAt(sort: Desc)])
  @@index([orderId])
  @@index([status])
}

model ReturnItem {
  id              String        @id @default(uuid())
  returnRequestId String
  orderItemId     String
  quantity        Int
  reason          String?
  returnRequest   ReturnRequest @relation(fields: [returnRequestId], references: [id], onDelete: Cascade)

  @@index([returnRequestId])
}

model Warehouse {
  id        String           @id @default(uuid())
  storeId   String
  name      String
  address   String?
  isDefault Boolean          @default(false)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  movements StockMovement[]
  store     Store            @relation(fields: [storeId], references: [id], onDelete: Cascade)
  stock     WarehouseStock[]

  @@index([storeId])
}

model WarehouseStock {
  id          String    @id @default(uuid())
  warehouseId String
  productId   String
  variantSku  String?
  quantity    Int       @default(0)
  reserved    Int       @default(0)
  available   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@unique([warehouseId, productId, variantSku])
  @@index([productId])
  @@index([warehouseId])
}

model StockMovement {
  id          String            @id @default(uuid())
  productId   String
  warehouseId String
  type        StockMovementType
  quantity    Int
  reason      String?
  orderId     String?
  createdAt   DateTime          @default(now())
  product     Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouse   Warehouse         @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@index([productId, createdAt(sort: Desc)])
  @@index([warehouseId])
}

model BackgroundJob {
  id         String              @id @default(uuid())
  type       BackgroundJobType
  status     BackgroundJobStatus @default(PENDING)
  payload    Json                @default("{}")
  runAt      DateTime            @default(now())
  startedAt  DateTime?
  finishedAt DateTime?
  error      String?
  attempts   Int                 @default(0)
  maxRetries Int                 @default(3)
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  @@index([status, runAt])
  @@index([type, status])
}

model ProductVariant {
  id         String      @id @default(uuid())
  productId  String
  name       String
  sku        String?
  price      Float?
  stock      Int         @default(0)
  options    Json
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  orderItems OrderItem[]
  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model ProductTranslation {
  id             String   @id @default(uuid())
  productId      String
  locale         String
  name           String
  description    String?
  seoTitle       String?
  seoDescription String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  product        Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, locale])
  @@index([productId])
}

model CategoryTranslation {
  id          String   @id @default(uuid())
  categoryId  String
  locale      String
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, locale])
  @@index([categoryId])
}

model TierPrice {
  id          String  @id @default(uuid())
  productId   String
  minQuantity Int
  price       Float
  storeId     String
  product     Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  store       Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([productId, minQuantity])
  @@index([productId])
  @@index([storeId])
}

model CustomerGroupPrice {
  id              String        @id @default(uuid())
  customerGroupId String
  productId       String
  price           Float
  customerGroup   CustomerGroup @relation(fields: [customerGroupId], references: [id], onDelete: Cascade)
  product         Product       @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([customerGroupId, productId])
  @@index([customerGroupId])
  @@index([productId])
}

model ErrorLog {
  id         String   @id @default(uuid())
  type       String
  message    String
  stackTrace String?
  userId     String?
  storeId    String?
  url        String?
  userAgent  String?
  severity   String   @default("ERROR")
  metadata   Json?    @default("{}")
  createdAt  DateTime @default(now())

  @@index([type])
  @@index([severity])
  @@index([userId])
  @@index([storeId])
  @@index([createdAt(sort: Desc)])
}

model AdCampaign {
  id               String           @id @default(uuid())
  storeId          String
  name             String
  type             AdCampaignType   @default(CPC)
  status           AdCampaignStatus @default(DRAFT)
  dailyBudget      Float?
  totalBudget      Float?
  maxBid           Float
  currentBid       Float
  targetCategories String[]         @default([])
  targetKeywords   String[]         @default([])
  targetStores     String[]         @default([])
  placements       AdPlacement[]    @default([])
  title            String
  description      String?
  imageUrl         String?
  linkUrl          String
  startDate        DateTime?
  endDate          DateTime?
  impressionsCount Int              @default(0)
  clicksCount      Int              @default(0)
  conversionsCount Int              @default(0)
  spentAmount      Float            @default(0)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  store            Store            @relation(fields: [storeId], references: [id], onDelete: Cascade)
  items            AdCampaignItem[]
  adImpressions    AdImpression[]

  @@index([storeId])
  @@index([status])
  @@index([createdAt])
}

model AdCampaignItem {
  id         String     @id @default(uuid())
  campaignId String
  productId  String?
  categoryId String?
  campaign   AdCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
}

model AdImpression {
  id         String      @id @default(uuid())
  campaignId String
  storeId    String?
  userId     String?
  placement  AdPlacement
  occurredAt DateTime    @default(now())
  clicked    Boolean     @default(false)
  converted  Boolean     @default(false)
  campaign   AdCampaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([storeId])
  @@index([occurredAt])
}

model PlatformMonetization {
  id                  String   @id @unique @default(uuid())
  adEnabled           Boolean  @default(true)
  minCpcBid           Float    @default(0.01)
  maxCpcBid           Float    @default(100.0)
  minCpaBid           Float    @default(0.1)
  maxCpaBid           Float    @default(1000.0)
  platformCommission  Float    @default(0.05)
  totalRevenue        Float    @default(0)
  adRevenue           Float    @default(0)
  subscriptionRevenue Float    @default(0)
  commissionRevenue   Float    @default(0)
  updatedAt           DateTime @updatedAt
}

model MarketplaceTheme {
  id               String   @id @default(uuid())
  name             String
  slug             String   @unique
  description      String?
  config           Json     @default("{}")
  primaryColor     String   @default("#3b82f6")
  secondaryColor   String   @default("#64748b")
  accentColor      String   @default("#22c55e")
  backgroundColor  String   @default("#ffffff")
  textColor        String   @default("#1e293b")
  headerStyle      String   @default("default")
  footerStyle      String   @default("default")
  productCardStyle String   @default("default")
  showRatings      Boolean  @default(true)
  showCompare      Boolean  @default(true)
  showWishlist     Boolean  @default(true)
  quickViewEnabled Boolean  @default(true)
  isActive         Boolean  @default(false)
  isPremium        Boolean  @default(false)
  price            Float    @default(0)
  previewImageUrl  String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([isActive])
  @@index([slug])
}

model SellerHealthScore {
  id                    String   @id @default(uuid())
  storeId               String   @unique
  overallScore          Float    @default(50)
  orderFulfillmentScore Float    @default(50)
  customerServiceScore  Float    @default(50)
  productQualityScore   Float    @default(50)
  shippingSpeedScore    Float    @default(50)
  communicationScore    Float    @default(50)
  totalOrders           Int      @default(0)
  completedOrders       Int      @default(0)
  cancelledOrders       Int      @default(0)
  avgShippingTimeHours  Float    @default(0)
  avgResponseTimeHours  Float    @default(0)
  returnRate            Float    @default(0)
  disputeRate           Float    @default(0)
  avgRating             Float    @default(0)
  tier                  String   @default("BRONZE")
  lastCalculatedAt      DateTime @default(now())
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  store                 Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@index([overallScore])
  @@index([tier])
}

model DisputeCase {
  id                  String           @id @default(uuid())
  orderId             String
  storeId             String
  userId              String
  assignedAdminId     String?
  type                DisputeType
  status              DisputeStatus    @default(OPEN)
  title               String
  description         String
  customerNote        String?
  sellerNote          String?
  adminNote           String?
  requestedResolution String           @default("REFUND")
  refundAmount        Float?
  finalDecision       String?
  decisionReason      String?
  resolvedAt          DateTime?
  priority            String           @default("NORMAL")
  daysOpen            Int              @default(0)
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  order               Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  store               Store            @relation(fields: [storeId], references: [id], onDelete: Cascade)
  user                User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages            DisputeMessage[]

  @@index([storeId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([priority])
}

model DisputeMessage {
  id              String      @id @default(uuid())
  disputeCaseId   String
  senderId        String?
  senderType      String
  message         String
  attachments     String[]    @default([])
  isVisibleToBoth Boolean     @default(true)
  createdAt       DateTime    @default(now())
  disputeCase     DisputeCase @relation(fields: [disputeCaseId], references: [id], onDelete: Cascade)

  @@index([disputeCaseId])
  @@index([senderType])
}

model AdminNotification {
  id          String                    @id @default(uuid())
  type        AdminNotificationType
  severity    AdminNotificationSeverity @default(MEDIUM)
  title       String
  message     String
  storeId     String?
  userId      String?
  orderId     String?
  disputeId   String?
  actionLabel String?
  actionUrl   String?
  isRead      Boolean                   @default(false)
  isArchived  Boolean                   @default(false)
  metadata    Json                      @default("{}")
  createdAt   DateTime                  @default(now())
  expiresAt   DateTime?
  store       Store?                    @relation(fields: [storeId], references: [id])
  user        User?                     @relation(fields: [userId], references: [id])

  @@index([isRead])
  @@index([severity])
  @@index([type])
  @@index([createdAt])
  @@index([storeId])
}

model SellerLeaderboard {
  id                 String    @id @default(uuid())
  storeId            String    @unique
  storeName          String
  overallRank        Int
  categoryRanks      Json      @default("{}")
  healthScore        Float
  totalSales         Float
  totalOrders        Int
  avgRating          Float
  responseRate       Float
  onTimeShipmentRate Float
  period             String    @default("MONTHLY")
  periodStart        DateTime
  periodEnd          DateTime?
  badges             String[]  @default([])
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  store              Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([overallRank])
  @@index([period])
  @@index([healthScore])
}

